# EasyOCR model cache (downloaded at runtime)
**/.ocr_cache/

# Playwright browsers (downloaded at runtime)
**/.playwright-browsers/

# Scrapling / swiftshadow cache
**/.scrapling-cache/

# Output JSON / Excel / CSV — DO NOT commit (each run generates a fresh timestamped set)
output/
!output/.gitkeep

# Historical runs (manually preserved, valuable data)
!data/outputs/historical/

